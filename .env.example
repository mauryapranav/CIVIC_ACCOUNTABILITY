# Copy this to .env and fill in your values
# NEVER commit .env to git

# Required: Google Gemini API key
# Get from: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_gemini_api_key_here

# Optional: model override (default: gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash

# Optional: SendGrid for real email sending
# Leave blank to use email DRAFT mode (safe for demo)
SENDGRID_API_KEY=

# Optional: portal base URL for email links
PORTAL_URL=https://wardwatch-2c4fd.web.app
