# Copy this file to .env and fill in your values
# NEVER commit .env to git — it's in .gitignore

# ── API Key (Required) ────────────────────────────────────────────────────────
# New format (AQ. prefix) — from https://aistudio.google.com/apikey
# Google AI Studio now issues AQ. keys by default (more secure)
GEMINI_API_KEY=AQ.your_new_key_here

# Legacy format (AIzaSy prefix) — still works if you have an older key
# GOOGLE_API_KEY=AIzaSy...your_old_key_here

# ── Model (Optional) ──────────────────────────────────────────────────────────
# Default: gemini-2.0-flash
# Alternatives if rate-limited: gemini-2.0-flash-lite | gemini-2.5-flash
GEMINI_MODEL=gemini-2.0-flash

# ── Email (Optional) ──────────────────────────────────────────────────────────
# Leave blank — draft mode works fine for demo without sending real emails
SENDGRID_API_KEY=

# ── Portal URL (Optional) ─────────────────────────────────────────────────────
PORTAL_URL=https://wardwatch-2c4fd.web.app
