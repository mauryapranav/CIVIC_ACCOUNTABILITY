# Copy this file to .env and fill in your values
# NEVER commit .env to git — it's in .gitignore

# ── API Key (Required) ────────────────────────────────────────────────────────
# New format (AQ. prefix) — from https://aistudio.google.com/apikey
GEMINI_API_KEY=AQ.your_key_here

# Legacy format (AIzaSy prefix) — still works if you have an older key
# GOOGLE_API_KEY=AIzaSy...your_old_key_here

# ── Model (Optional) ──────────────────────────────────────────────────────────
# Default: gemini-2.5-flash-lite (cheapest, best free-tier quota)
# Fallback order if this fails: gemini-2.5-flash → gemini-3.5-flash
# NOTE: gemini-2.0-flash and gemini-1.5-flash are DEPRECATED (shut down June 2026)
GEMINI_MODEL=gemini-2.5-flash-lite

# ── Email (Optional) ──────────────────────────────────────────────────────────
# Leave blank — draft mode works fine for demo without sending real emails
SENDGRID_API_KEY=

# ── Portal URL (Optional) ─────────────────────────────────────────────────────
PORTAL_URL=https://wardwatch-2c4fd.web.app
